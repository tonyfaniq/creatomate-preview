# Used by the backend API route (keep this secret!)
CREATOMATE_API_KEY=your_secret_api_key_here

# Used by the frontend Preview SDK (this one is public)
NEXT_PUBLIC_CREATOMATE_PUBLIC_TOKEN=public-xxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: ID of a template in your Creatomate project to load initially
NEXT_PUBLIC_TEMPLATE_ID=your_template_id_here 